NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_ENABLE_MSW=false
# Absolute origin of the deployed site — sitemap.xml, feed.xml, canonical URLs,
# OpenGraph metadataBase all consume this at *build* time. MUST be set in prod
# (e.g. https://blog.example.com) or your SEO artifacts will point at localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
